{
  "name": "menteleve",
  "version": "1.0.0",
  "description": "Plataforma digital de organização pessoal, hábitos, metas e finanças",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "npx nodemon src/server.js",
    "db:migrate": "npx prisma migrate dev --name init",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma migrate reset --force",
    "db:generate": "npx prisma generate",
    "setup": "npm install && npx prisma generate && npx prisma migrate dev --name init && node prisma/seed.js",
    "test": "jest --runInBand",
    "test:watch": "jest --runInBand --watch",
    "test:coverage": "jest --runInBand --coverage",
    "lint": "eslint src/"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [],
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "jest": "^30.4.2",
    "nodemon": "^3.0.0",
    "prisma": "^6.0.0",
    "supertest": "^7.2.2"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "express": "^4.18.2"
  }
}
