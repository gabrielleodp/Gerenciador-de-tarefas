{
  "name": "menteleve",
  "version": "1.0.0",
  "description": "Plataforma digital de organização pessoal, hábitos, metas e finanças",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "npx nodemon src/server.js",
    "db:migrate": "npx prisma migrate dev --name init",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma migrate reset --force",
    "db:generate": "npx prisma generate",
    "setup": "npm install && npx prisma generate && npx prisma migrate dev --name init && node prisma/seed.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [],
  "author": "Adrielly Costa, Gabrielle Oliveira, Luisa Varejão",
  "license": "ISC",
  "devDependencies": {
    "nodemon": "^3.0.0",
    "prisma": "^6.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "express": "^4.18.2"
  }
}
