// MenteLeve - Schema Prisma com SQLite
// Alunos: Adrielly Costa, Gabrielle Oliveira e Luisa Varejão

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Tabela: usuarios
// Armazena os usuários cadastrados na plataforma
// ─────────────────────────────────────────────
model Usuario {
  id         String   @id @default(uuid())
  nome       String
  email      String   @unique
  senhaHash  String   @map("senha_hash")
  premium    Boolean  @default(false)
  criadoEm   DateTime @default(now()) @map("criado_em")

  // Relacionamentos 1:N
  tarefas    Tarefa[]
  habitos    Habito[]
  metas      Meta[]
  financas   Financa[]

  @@map("usuarios")
}

// ─────────────────────────────────────────────
// Tabela: tarefas
// Atividades criadas pelos usuários
// ─────────────────────────────────────────────
model Tarefa {
  id           String    @id @default(uuid())
  usuarioId    String    @map("usuario_id")
  titulo       String
  dataPrevista DateTime? @map("data_prevista")
  concluida    Boolean   @default(false)
  criadoEm     DateTime  @default(now()) @map("criado_em")

  // Relacionamento com Usuario (N:1)
  usuario      Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("tarefas")
}

// ─────────────────────────────────────────────
// Tabela: habitos
// Hábitos recorrentes que o usuário deseja desenvolver
// ─────────────────────────────────────────────
model Habito {
  id         String          @id @default(uuid())
  usuarioId  String          @map("usuario_id")
  nome       String
  frequencia FrequenciaHabito
  criadoEm   DateTime        @default(now()) @map("criado_em")

  // Relacionamentos
  usuario    Usuario          @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  registros  RegistroHabito[]

  @@map("habitos")
}

// ─────────────────────────────────────────────
// Tabela: registros_habito
// Histórico diário de conclusão de hábitos
// ─────────────────────────────────────────────
model RegistroHabito {
  id         String   @id @default(uuid())
  habitoId   String   @map("habito_id")
  data       DateTime
  concluido  Boolean  @default(false)

  // Relacionamento com Habito (N:1)
  habito     Habito   @relation(fields: [habitoId], references: [id], onDelete: Cascade)

  // Regra de negócio: um hábito só pode ser registrado uma vez por dia
  @@unique([habitoId, data])
  @@map("registros_habito")
}

// ─────────────────────────────────────────────
// Tabela: metas
// Objetivos definidos pelos usuários com prazo e progresso
// ─────────────────────────────────────────────
model Meta {
  id            String   @id @default(uuid())
  usuarioId     String   @map("usuario_id")
  titulo        String
  prazo         DateTime
  progressoPct  Int      @default(0) @map("progresso_pct")
  concluida     Boolean  @default(false)
  criadoEm      DateTime @default(now()) @map("criado_em")

  // Relacionamento com Usuario (N:1)
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("metas")
}

// ─────────────────────────────────────────────
// Tabela: financas
// Movimentações financeiras (entradas e saídas)
// Obs: o saldo é calculado dinamicamente (entradas - saídas)
// ─────────────────────────────────────────────
model Financa {
  id         String         @id @default(uuid())
  usuarioId  String         @map("usuario_id")
  tipo       TipoFinanca
  valor      Float
  descricao  String?
  data       DateTime
  criadoEm   DateTime       @default(now()) @map("criado_em")

  // Relacionamento com Usuario (N:1)
  usuario    Usuario        @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("financas")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────
enum FrequenciaHabito {
  diaria
  semanal
}

enum TipoFinanca {
  entrada
  saida
}
